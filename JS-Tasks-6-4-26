//You will be given an array of numbers. You have to sort the odd numbers in ascending order while leaving the even numbers at their original positions.

function sortArray(array) {
  const odds = arr.filter(n => n % 2 !== 0).sort((a, b) => a - b);
  let index = 0;
  const result = arr.map(n => n % 2 !== 0 ? odds[index++] : n);
  return result;
}

//In this kata you are required to, given a string, replace every letter with its position in the alphabet.

//If anything in the text isn't a letter, ignore it and don't return it.

//"a" = 1, "b" = 2, etc.

function alphabetPosition(text) {
  const alphabetCount = {};
  for (let i = 0; i < 26; i++) {
    const char = String.fromCharCode(97 + i);
    alphabetCount[char] = i + 1;
  }
  const lettersOnly = text.split("");
  const clearText = lettersOnly.map(str => str.replace(/[^a-zA-Z]/g, ""));
  const result = clearText
    .filter(item => item !== "")
    .map(item => alphabetCount[item.toLowerCase()]);
  const str = result.join(' ')
  return str;
}


